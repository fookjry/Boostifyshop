# Server Configuration
PORT=3000
NODE_ENV=production

# Firebase Configuration (Optional if firebase-applet-config.json exists)
# These will override the JSON config if provided
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_DATABASE_ID=

# EasySlip API (Slip Verification)
EASY_SLIP_API_KEY=

# TrueMoney Proxy (Optional)
TRUEMONEY_PROXY=
TRUEMONEY_GAS_URL=https://script.google.com/macros/s/AKfycbwoxl_G9I_4bxFUVktosdbz3C2kXIw_91L2nSyl6MYKcokFEXvy8J1Yt3A--_P320ld/exec

# 3x-ui Default Server (Optional, if not using Firestore for server management)
THREE_X_UI_URL=
THREE_X_UI_USERNAME=
THREE_X_UI_PASSWORD=
