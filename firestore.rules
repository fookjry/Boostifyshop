rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "jry.fook@gmail.com" || 
         request.auth.token.email == "server@local.host" ||
         request.auth.uid == "JL3epuiyeeSzfek2gQUUIekzndj2" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    function isValidUser(data) {
      return data.email is string && data.email.size() < 100 &&
             data.balance is number &&
             data.role in ['user', 'admin'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && 
                    isValidUser(incoming()) &&
                    (incoming().role == 'user' || 
                     (incoming().role == 'admin' && (request.auth.token.email == "jry.fook@gmail.com" || request.auth.token.email == "server@local.host" || request.auth.uid == "JL3epuiyeeSzfek2gQUUIekzndj2"))) && 
                    incoming().balance == 0;
      allow update: if (isAdmin() && isValidUser(incoming())) || 
                    (isOwner(userId) && 
                     isValidUser(incoming()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['lastTrialAt', 'lastAdClaimAt', 'discordId', 'phoneNumber', 'trueMoneyNumber']));
      allow delete: if isAdmin();
    }

    function isValidNetwork(data) {
      return data.keys().hasAll(['name', 'inboundId', 'status', 'color']) &&
             data.keys().hasOnly(['name', 'inboundId', 'status', 'color']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.inboundId is number &&
             data.status in ['open', 'closed'] &&
             data.color is string && data.color.size() > 0;
    }

    // Server Rules
    match /servers/{serverId} {
      allow read: if isSignedIn() && isValidId(serverId);
      allow write: if isAdmin();
      
      match /private/credentials {
        allow read, write: if isAdmin();
      }
    }

    // Network Rules
    match /networks/{networkId} {
      allow read: if isSignedIn() && isValidId(networkId);
      allow write: if isAdmin() && isValidNetwork(incoming());
    }

    // Device Options Rules
    match /device_options/{optionId} {
      allow read: if isSignedIn() && isValidId(optionId);
      allow write: if isAdmin();
    }

    function isValidVPN(data) {
      return data.userId is string &&
             data.serverId is string &&
             data.uuid is string && data.uuid.size() < 100 &&
             data.config is string && data.config.size() < 5000 &&
             data.expireAt is string &&
             data.status in ['active', 'expired'] &&
             data.network is string;
    }

    // VPN Config Rules
    match /vpns/{vpnId} {
      allow read: if isSignedIn() && isValidId(vpnId) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create, update: if isAdmin() && isValidVPN(incoming());
      allow delete: if isAdmin();
    }

    // Transaction Rules
    match /transactions/{txId} {
      allow read: if isSignedIn() && isValidId(txId) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // Used Slips Rules
    match /used_slips/{slipId} {
      allow read, write: if isAdmin();
    }

    // Manual Topups Rules
    match /manual_topups/{id} {
      allow read: if isSignedIn() && isValidId(id) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // Global Settings Rules
    match /settings/{settingId} {
      allow read: if (settingId != 'payment_keys' || isAdmin()) && isValidId(settingId);
      allow write: if isAdmin() && isValidId(settingId);
    }

    // Tickets Rules
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && isValidId(ticketId) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && isValidId(messageId) && (get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid || isAdmin());
        allow create, update, delete: if isAdmin();
      }
    }

    // Linkvertise Tracking Rules
    match /linkvertise_sessions/{sessionId} {
      allow read, write: if isAdmin();
    }
    match /linkvertise_claims/{claimId} {
      allow read, write: if isAdmin();
    }
  }
}
